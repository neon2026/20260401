# ============================================================================
# Docker Deployment Environment Variables
# ============================================================================
# Copy this file to .env.docker and fill in your actual values

# ============================================================================
# Database Configuration (MySQL for system metadata)
# ============================================================================
DATABASE_URL=mysql://appuser:apppassword@mysql:3306/enterprise_ai
MYSQL_ROOT_PASSWORD=root
MYSQL_USER=appuser
MYSQL_PASSWORD=apppassword

# ============================================================================
# Oracle Database Configuration (for data consultation)
# ============================================================================
ORACLE_HOST=192.168.59.166
ORACLE_PORT=1521
ORACLE_SID=orcl
ORACLE_USER=neon
ORACLE_PASSWORD=oracle

# ============================================================================
# API Keys and Secrets
# ============================================================================
DEEPSEEK_API_KEY=sk-105b5973d1744993a6fceab8e8efcb48
JWT_SECRET=your-production-jwt-secret-change-this

# ============================================================================
# OAuth Configuration (Manus)
# ============================================================================
VITE_APP_ID=your-app-id
OAUTH_SERVER_URL=https://oauth.manus.im
VITE_OAUTH_PORTAL_URL=https://portal.manus.im
OWNER_OPEN_ID=your-owner-id
OWNER_NAME=Your Name

# ============================================================================
# Manus Built-in APIs
# ============================================================================
BUILT_IN_FORGE_API_URL=https://forge.manus.im
BUILT_IN_FORGE_API_KEY=your-forge-api-key
VITE_FRONTEND_FORGE_API_URL=https://forge.manus.im
VITE_FRONTEND_FORGE_API_KEY=your-frontend-forge-api-key

# ============================================================================
# Analytics Configuration
# ============================================================================
VITE_ANALYTICS_ENDPOINT=https://analytics.manus.im
VITE_ANALYTICS_WEBSITE_ID=your-website-id

# ============================================================================
# Application Branding
# ============================================================================
VITE_APP_TITLE=Enterprise AI Solution
VITE_APP_LOGO=https://example.com/logo.png

# ============================================================================
# Node Environment
# ============================================================================
NODE_ENV=production
